# ── LOCAL (bun inlines these at build time) ───────────────────────────────
# These are written by `npx convex dev` — do not set manually.
CONVEX_DEPLOYMENT=dev:your-deployment-name
CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_SITE_URL=https://your-deployment.convex.site

# ── CONVEX DEPLOYMENT ENV VARS ─────────────────────────────────────────────
# These are set in the Convex cloud, NOT in this file.
# Run these once after `npx convex dev`:
#
#   npx convex env set SITE_URL <value of CONVEX_SITE_URL above>
#   npx convex env set JWT_PRIVATE_KEY "..."   # EC P-256 private key PEM
#   npx convex env set JWKS '{"keys":[...]}'   # matching public key JWK set
#   npx convex env set AUTH_RESEND_KEY re_xxx  # from resend.com dashboard
#   npx convex env set AUTH_EMAIL "Quincy <noreply@yourdomain.com>"  # optional
#
# To generate JWT_PRIVATE_KEY + JWKS in one step, run:
#   bun scripts/gen-auth-keys.ts
# (see that file for instructions)
