{
  "name": "quincy-desktop",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "start": "cross-env EXPO_NO_TYPESCRIPT_SETUP=1 expo start --port 8081",
    "start:rn": "react-native start --port 8081",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "macos": "react-native run-macos --project-path macos --scheme quincy-desktop-macOS",
    "windows": "rnc-cli run-windows",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "expo": "^54.0.33",
    "expo-desktop-config-plugins": "^1.1.34",
    "expo-desktop-modules-core": "^54.0.13",
    "expo-desktop-stubs": "^54.0.13",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.4",
    "react-native": "0.81.6",
    "react-native-macos": "0.81.7",
    "react-native-windows": "0.81.18"
  },
  "devDependencies": {
    "@react-native-community/cli": "latest",
    "@react-native/metro-config": "~0.81.0",
    "@rnx-kit/metro-config": "latest",
    "@types/react": "~19.1.0",
    "cross-env": "^10.1.0",
    "expo-desktop": "0.1.37",
    "typescript": "^5.9.3"
  },
  "overrides": {
    "react": "19.1.4",
    "react-native": "0.81.6"
  }
}
